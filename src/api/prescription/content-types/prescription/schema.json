{
  "kind": "collectionType",
  "collectionName": "prescriptions",
  "info": {
    "singularName": "prescription",
    "pluralName": "prescriptions",
    "displayName": "Prescription",
    "description": "Recetas médicas - ePrescription Clinical App"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "patient": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::patient.patient",
      "required": true
    },
    "doctor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::doctor.doctor",
      "required": true
    },
    "medications": {
      "type": "json",
      "required": true,
      "default": []
    },
    "dosage": {
      "type": "text"
    },
    "instructions": {
      "type": "text"
    },
    "clinic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::clinic.clinic"
    },
    "appointment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::appointment.appointment"
    }
  }
}
